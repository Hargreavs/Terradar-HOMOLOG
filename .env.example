# Direct connection (porta 5432, IPv6) — usar APENAS para batch overnight.
# Necessário para batch-scores.ts evitar prepared-statement issues do transaction pooler.
# NÃO usar em CI/CD ou Express — manter DATABASE_URL no 6543.
DATABASE_URL_BATCH=

# Sentinel Hub (Copernicus Data Space) — só no servidor Express; não usar VITE_.
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
